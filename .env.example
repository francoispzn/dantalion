# Copy to .env to set defaults. All variables are optional.

# Default model spec: kind:model (ollama / openai / llama-cpp / replay)
DANTALION_MODEL=ollama:llama3.1

# Base URL for ollama or an OpenAI-compatible server
# DANTALION_BASE_URL=http://localhost:11434
# DANTALION_BASE_URL=http://localhost:8000/v1

# API key, only used by the openai-compatible adapter
# DANTALION_API_KEY=

# Run shape
DANTALION_TEMPERATURE=0.1
DANTALION_MAX_STEPS=12
# DANTALION_MAX_TOKENS=
DANTALION_PLAN=true
DANTALION_REVIEW=true
